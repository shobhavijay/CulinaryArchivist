# ─────────────────────────────────────────────────────────────────────────────
# CulinaryArchivist — environment configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────


# ── LLM Backend ───────────────────────────────────────────────────────────────
# Choose one: "ollama" (local) or "anthropic" (cloud)
LLM_BACKEND=ollama


# ── Ollama settings (used when LLM_BACKEND=ollama) ───────────────────────────
# Ollama must be running: https://ollama.com
# Pull required models with: ollama pull <model_name>

OLLAMA_BASE_URL=http://localhost:11434

# Vision model — reads recipe images verbatim (step 1 of 2-step OCR)
VISION_MODEL=llama3.2-vision:11b

# Text model — structures OCR output; runs historian, cross-verifier, reflexion prompts
TEXT_MODEL=mistral:7b-instruct

# Optional hard timeout for Ollama calls in seconds.
# Leave blank (no timeout) for local CPU models where generation time is unpredictable.
# Example: OLLAMA_TIMEOUT=600
OLLAMA_TIMEOUT=


# ── Anthropic API settings (used when LLM_BACKEND=anthropic) ─────────────────
# Obtain your key at: https://console.anthropic.com/keys

ANTHROPIC_API_KEY=your-anthropic-api-key-here

CLAUDE_VISION_MODEL=claude-opus-4-7
CLAUDE_TEXT_MODEL=claude-opus-4-7


# ── OCR strategy ──────────────────────────────────────────────────────────────
# true  = PyMuPDF + Tesseract (fast, faithful — strongly recommended for handwritten recipes)
# false = vision LLM via Ollama or Anthropic (slower; may hallucinate on dense cursive)
USE_PYMUPDF=true

# Path to Tesseract language data files (only needed when USE_PYMUPDF=true).
# macOS Homebrew (Intel):       /usr/local/opt/tesseract/share/tessdata
# macOS Homebrew (Apple Silicon): /opt/homebrew/opt/tesseract/share/tessdata
# Ubuntu/Debian:                /usr/share/tesseract-ocr/4.00/tessdata
# Windows:                      C:\Program Files\Tesseract-OCR\tessdata
TESSDATA_PREFIX=/usr/local/opt/tesseract/share/tessdata


# ── Embedding model (ChromaDB duplicate detection) ────────────────────────────
# Served via Ollama (always local regardless of LLM_BACKEND).
# Pull with: ollama pull nomic-embed-text
EMBED_MODEL=nomic-embed-text


# ── Data directories (leave blank to use defaults relative to CWD) ───────────
# ARCHIVIST_REGISTRY_DIR=./culinary_archivist/registry
# ARCHIVIST_DATA_DIR=./data
# ARCHIVIST_OUTPUT_DIR=./output
# ARCHIVIST_DB_DIR=./db
# ARCHIVIST_CHROMA_DIR=./chroma


# ── Duplicate detection thresholds ───────────────────────────────────────────
# Cosine distance below this triggers the duplicate lexical guard check.
# 0.0 = identical · 1.0 = completely different
DUPLICATE_SIMILARITY_THRESHOLD=0.40

# Both guards must fail to dismiss a vector match as a false positive.
# nomic-embed-text maps short culinary texts into a narrow similarity band;
# these guards prevent unrelated dishes being flagged as duplicates.
DUPLICATE_TITLE_OVERLAP_MIN=0.30
DUPLICATE_INGREDIENT_JACCARD_MIN=0.25


# ── Reflexion persistent memory (Shinn et al., 2023 — arXiv:2303.11366) ──────
# JSON file where verbal OCR lessons persist across sessions.
# Leave blank to use the default: db/reflexion_memory.json
REFLEXION_MEMORY_PATH=

# Max number of past reflections injected into each transcription prompt.
REFLEXION_MAX_MEMORY_ENTRIES=8


# ── Cross-Verifier Self-Refine (Madaan et al., 2023 — arXiv:2303.17651) ──────
# Max FEEDBACK→REFINE iterations per attribution. Each pass = 2 LLM calls.
CROSS_VERIFIER_MAX_REFINE_STEPS=3


# ── Full path quality thresholds ──────────────────────────────────────────────
# Transcription score below this → Reflexion retry loop
FULL_PATH_QUALITY_THRESHOLD=0.5
# Max OCR retry attempts before proceeding regardless of quality
FULL_PATH_MAX_RESTORER_LOOPS=3
# Max historian enrichment iterations
FULL_PATH_MAX_HISTORIAN_LOOPS=2
# Max ReAct tool calls per historian invocation (Wikipedia, web search, registry)
HISTORIAN_MAX_REACT_STEPS=4


# ── Discovery subagent ────────────────────────────────────────────────────────
# Set to true to enable auto-drafting of new regional registry entries when
# the cross-verifier cannot match a recipe to any known region.
DISCOVERY_ENABLED=false
DISCOVERY_UNKNOWN_SCORE_THRESHOLD=0.15
DISCOVERY_ORPHAN_RATIO_THRESHOLD=0.25
